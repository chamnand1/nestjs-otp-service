              "type": "tm.Actor",
              "name": "SMS Gateway (Twilio/SNS)",
              "description": "Third-party provider สำหรับส่ง OTP SMS ไปยังผู้ใช้",
              "outOfScope": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "threats": [
                {
                  "id": "threat-t2",
                  "title": "SMS Interception (SS7)",
                  "type": "Tampering",
                  "status": "Open",
                  "severity": "High",
                  "description": "ผู้โจมตีใช้ช่องโหว่ SS7 protocol ดัก SMS ระหว่างทาง",
                  "mitigation": "แนะนำให้ใช้ TOTP (Authenticator App) แทน SMS สำหรับ high-value transaction. SMS OTP ยังใช้ได้สำหรับ low-risk"
                },
                {
                  "id": "threat-d2",
                  "title": "SMS Bombing Cost Attack",
                  "type": "Denial of service",
                  "status": "Mitigated",
                  "severity": "Medium",
                  "description": "ผู้โจมตีทำให้ค่า SMS พุ่งโดย flood request ไปยัง SMS Gateway",
                  "mitigation": "Rate limit ก่อนถึง SMS Gateway. Budget cap กับ provider. Dummy session ไม่ส่ง SMS จริง"
                }
              ]
            }
