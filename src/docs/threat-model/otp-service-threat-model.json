            "angle": 0,
            "id": "actor-user",
            "z": 1,
            "hasOpenThreats": true,
            "attrs": {
              "text": {
                "text": "User / Mobile App"
              }
            },
            "data": {
              "type": "tm.Actor",
              "name": "User / Mobile App",
              "description": "ผู้ใช้งานที่ขอและยืนยัน OTP ผ่าน mobile หรือ web",
              "outOfScope": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "threats": [
                {
                  "id": "threat-s1",
                  "title": "SIM Swap Attack",
                  "type": "Spoofing",
                  "status": "Open",
                  "severity": "High",
                  "description": "ผู้โจมตีแจ้งซิมหายและขอซิมใหม่จาก carrier เพื่อรับ OTP SMS แทนเจ้าของบัญชีจริง",
                  "mitigation": "ตรวจสอบว่าซิมเพิ่งเปลี่ยนใน 72 ชม. หากใช่ให้ block และแจ้ง email เจ้าของบัญชี รองรับ TOTP สำหรับ high-risk action"
                },
                {
                  "id": "threat-s2",
                  "title": "SMS Bombing — ผู้โจมตีสุ่มเบอร์",
                  "type": "Denial of service",
                  "status": "Mitigated",
                  "severity": "High",
                  "description": "ผู้โจมตีสุ่มเบอร์โทรศัพท์แล้วยิง OTP request เพื่อ DoS SMS Gateway และ spam เหยื่อ",
                  "mitigation": "Rate limit 3 req/min และ 10 req/hr ต่อ IP, Dummy session สำหรับเบอร์ที่ไม่ได้ลงทะเบียน, CAPTCHA"
                }
              ]
            }
          },
          {
            "type": "tm.Process",
            "size": {
              "width": 120,
              "height": 60
            },
            "position": {
              "x": 240,
              "y": 120
            },
            "angle": 0,
            "id": "proc-api-gateway",
            "z": 2,
            "hasOpenThreats": true,
            "attrs": {
              "text": {
                "text": "API Gateway\n(ThrottlerGuard)"
              }
            },
            "data": {
              "type": "tm.Process",
              "name": "API Gateway (ThrottlerGuard)",
              "description": "รับ HTTP request, ตรวจ rate limit, validate DTO ด้วย ValidationPipe",
              "outOfScope": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "threats": [
                {
                  "id": "threat-d1",
                  "title": "Request Flood / DoS",
                  "type": "Denial of service",
                  "status": "Mitigated",
                  "severity": "High",
                  "description": "ผู้โจมตียิง request จำนวนมากเพื่อทำให้ API Gateway ล่ม",
                  "mitigation": "ThrottlerModule: short 3req/min, long 10req/hr. Helmet headers. CORS จำกัด origin"
                },
                {
                  "id": "threat-i1",
                  "title": "Stack Trace Leakage",
                  "type": "Information disclosure",
                  "status": "Mitigated",
                  "severity": "Medium",
                  "description": "Internal error expose stack trace หรือ implementation detail ไปยัง client",
                  "mitigation": "GlobalExceptionFilter คืน generic error message เสมอ ไม่ expose stack trace"
                }
              ]
            }
          },
          {
            "type": "tm.Process",
            "size": {
              "width": 120,
              "height": 60
            },
            "position": {
              "x": 240,
              "y": 260
            },
            "angle": 0,
            "id": "proc-otp-service",
            "z": 3,
            "hasOpenThreats": true,
            "attrs": {
              "text": {
                "text": "OTP Service\n(Business Logic)"
              }
            },
            "data": {
              "type": "tm.Process",
              "name": "OTP Service (Business Logic)",
              "description": "สร้าง OTP ด้วย CSPRNG, จัดการ lockout, ตรวจ session, เรียก SMS Gateway",
              "outOfScope": false,
              "reasonOutOfScope": "",
              "hasOpenThreats": true,
              "threats": [
                {
                  "id": "threat-e1",
                  "title": "Replay Attack",
                  "type": "Elevation of privilege",
                  "status": "Mitigated",
                  "severity": "High",
                  "description": "ผู้โจมตีดัก OTP ที่ถูกต้องแล้วนำกลับมาใช้ซ้ำ",
                  "mitigation": "OTP ถูก delete ทันทีหลัง verify สำเร็จ (one-time use). TTL 5 นาที. Bind OTP กับ sessionId+phone"
                },
                {
                  "id": "threat-e2",
                  "title": "Brute Force OTP",
                  "type": "Elevation of privilege",
                  "status": "Mitigated",
                  "severity": "High",
                  "description": "OTP 6 หลักมี 1,000,000 combinations — โจมตีได้ถ้าไม่มี rate limit",
                  "mitigation": "Progressive lockout: 5 fail=5min, 10 fail=30min, 15 fail=24hr. Max 5 attempts ต่อ session แล้ว invalidate"
                },
                {
                  "id": "threat-r1",
                  "title": "Repudiation — ปฏิเสธการขอ OTP",
                  "type": "Repudiation",
                  "status": "Mitigated",
                  "severity": "Medium",
                  "description": "ผู้ใช้อ้างว่าไม่ได้ขอ OTP หรือไม่ได้ทำธุรกรรม",
                  "mitigation": "Audit log ทุก request พร้อม timestamp, IP, masked phone number (ไม่ log OTP value)"
                },
                {
                  "id": "threat-i2",
                  "title": "User Enumeration",
                  "type": "Information disclosure",
                  "status": "Mitigated",
                  "severity": "Medium",
                  "description": "Response ต่างกันระหว่างเบอร์ที่ลงทะเบียนแล้ว vs ยังไม่ลงทะเบียน ทำให้ enumerate users ได้",
                  "mitigation": "ตอบ generic message เสมอ 'If this number is registered, OTP has been sent.' คืน dummy sessionId สำหรับเบอร์ที่ไม่มีในระบบ"
                }
              ]
            }
          },
