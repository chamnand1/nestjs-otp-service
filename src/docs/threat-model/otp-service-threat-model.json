            "attrs": {
              "text": {
                "text": "Redis\n(OTP Store)"
              }
            },
            "data": {
              "type": "tm.Store",
              "name": "Redis (OTP Store)",
              "description": "เก็บ hashed OTP, sessionId, phone, attempt count พร้อม TTL 5 นาที",
              "outOfScope": false,
              "reasonOutOfScope": "",
              "isALog": false,
              "storesCredentials": false,
              "isEncrypted": false,
              "hasOpenThreats": true,
              "threats": [
                {
                  "id": "threat-t1",
                  "title": "OTP Stored as Plaintext",
                  "type": "Tampering",
                  "status": "Mitigated",
                  "severity": "High",
                  "description": "หาก OTP ถูกเก็บเป็น plaintext ผู้ที่เข้าถึง Redis ได้จะขโมย OTP ทั้งหมดได้",
                  "mitigation": "เก็บเฉพาะ SHA-256(otp:sessionId) ไม่เก็บ OTP จริง. TTL auto-expire 300 วินาที"
                },
                {
                  "id": "threat-i3",
                  "title": "OTP Leaked via Logs",
                  "type": "Information disclosure",
                  "status": "Mitigated",
                  "severity": "High",
                  "description": "OTP value ปรากฏใน application logs หรือ Redis logs",
                  "mitigation": "ห้าม log OTP value เด็ดขาด. Mask phone number ใน logs ทุกที่. เก็บเฉพาะ hash"
                }
              ]
            }
          },
